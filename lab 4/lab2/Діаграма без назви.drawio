        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nleft to right direction\nskinparam shadowing false\n\nactor \&quot;Клієнт\&quot; as Client\nactor \&quot;Майстер\&quot; as Barber\nactor \&quot;Адміністратор\&quot; as Admin\n\nrectangle \&quot;Система Барбершопу\&quot; {\n  usecase \&quot;Авторизація\&quot; as Auth\n  \n  usecase \&quot;Записатися на дату і час\&quot; as Book\n  usecase \&quot;Обрати послугу і майстра\&quot; as Choose\n  usecase \&quot;Переглянути історію\\nвідвідувань\&quot; as History\n  \n  usecase \&quot;Переглянути власний\\nграфік роботи\&quot; as ViewSchedule\n  usecase \&quot;Внести службову\\nпримітку клієнту\&quot; as AddNote\n  \n  usecase \&quot;Управляти графіками\\nвсіх майстрів\&quot; as ManageSched\n  usecase \&quot;Оформити продаж\\nсупутнього товару\&quot; as SellItem\n  usecase \&quot;Згенерувати звіт\\nефективності\&quot; as Report\n  usecase \&quot;Скасувати запис\&quot; as CancelBook\n}\n\n&#39; Зв&#39;язки Клієнта\nClient --&gt; Book\nClient --&gt; History\nBook ..&gt; Auth : &lt;&lt;include&gt;&gt;\nBook ..&gt; Choose : &lt;&lt;include&gt;&gt;\n\n&#39; Зв&#39;язки Майстра\nBarber --&gt; ViewSchedule\nBarber --&gt; AddNote\nAddNote ..&gt; Auth : &lt;&lt;include&gt;&gt;\n\n&#39; Зв&#39;язки Адміністратора\nAdmin --&gt; ManageSched\nAdmin --&gt; SellItem\nAdmin --&gt; Report\nManageSched &lt;.. CancelBook : &lt;&lt;extend&gt;&gt;\nSellItem ..&gt; Auth : &lt;&lt;include&gt;&gt;\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="LKNgzNRRrlhEpqycF2Ya-1">
