        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\nskinparam classAttributeIconSize 0\nskinparam shadowing false\nskinparam nodesep 60\nskinparam ranksep 70\nleft to right direction\n\nabstract class User {\n  # userId: Integer\n  # name: String\n  # phone: String\n  # email: String\n  # isActive: Boolean\n  + login(pass: String): Boolean\n  + logout(): void\n  + resetPassword(email: String): Boolean\n  + updateProfile(data: String): void\n  + getInfo(): String\n}\n\nclass Client {\n  - discountLevel: Integer\n  - totalSpent: Float\n  - preferences: String\n  - regDate: Date\n  - noShowCount: Integer\n  + bookSlot(date: Date): Boolean\n  + cancelBook(appId: Integer): void\n  + pay(amount: Float): Boolean\n  + leaveReview(text: String): void\n  + viewHistory(): String\n}\n\nclass Barber {\n  - specialization: String\n  - experienceYears: Integer\n  - rating: Float\n  - commissionRate: Integer\n  - currentStatus: String\n  + viewSchedule(date: Date): String\n  + startService(appId: Integer): void\n  + endService(appId: Integer): void\n  + addNote(clientId: Integer): Boolean\n  + takeBreak(mins: Integer): void\n}\n\nclass Admin {\n  - accessLevel: Integer\n  - shiftDate: Date\n  - processedSales: Integer\n  - warnings: String\n  - isSuperAdmin: Boolean\n  + confirmBook(appId: Integer): Boolean\n  + sellProduct(prodId: Integer): Boolean\n  + generateReport(type: String): File\n  + manageStock(prodId: Integer): void\n  + banClient(clientId: Integer): Boolean\n}\n\nclass Appointment {\n  - appId: Integer\n  - appDate: Date\n  - appTime: Time\n  - status: String\n  - totalCost: Float\n  + create(clientId: Integer): Boolean\n  + updateStatus(newStatus: String): void\n  + calculateTotal(): Float\n  + assignBarber(barberId: Integer): Boolean\n  + cancel(reason: String): void\n}\n\nclass Service {\n  - servId: Integer\n  - name: String\n  - durationMins: Integer\n  - price: Float\n  - category: String\n  + updatePrice(newPrice: Float): Boolean\n  + changeDuration(mins: Integer): void\n  + activate(): void\n  + deactivate(): void\n  + getDetails(): String\n}\n\nclass Product {\n  - prodId: Integer\n  - name: String\n  - brand: String\n  - stockQty: Integer\n  - price: Float\n  + checkStock(): Integer\n  + reserve(qty: Integer): Boolean\n  + sell(qty: Integer): Boolean\n  + restock(qty: Integer): void\n  + updatePrice(newPrice: Float): Boolean\n}\n\nclass Invoice {\n  - invId: Integer\n  - amount: Float\n  - issueDate: Date\n  - paymentMethod: String\n  - isPaid: Boolean\n  + generate(appId: Integer): Boolean\n  + processPayment(method: String): Boolean\n  + printReceipt(): File\n  + applyDiscount(percent: Integer): Float\n  + refund(): Boolean\n}\n\nclass Schedule {\n  - schedId: Integer\n  - workDate: Date\n  - startTime: Time\n  - endTime: Time\n  - isDayOff: Boolean\n  + setShift(start: Time, end: Time): void\n  + addBreak(time: Time): Boolean\n  + checkAvailability(time: Time): Boolean\n  + bookSlot(time: Time): void\n  + clearDay(): void\n}\n\nclass Review {\n  - revId: Integer\n  - rating: Integer\n  - comment: String\n  - revDate: Date\n  - isPublished: Boolean\n  + create(text: String): Boolean\n  + edit(text: String): void\n  + delete(): Boolean\n  + publish(): void\n  + hide(): void\n}\n\n&#39; Відношення\nUser &lt;|-- Client\nUser &lt;|-- Barber\nUser &lt;|-- Admin\n\nClient \&quot;1\&quot; -- \&quot;0..*\&quot; Appointment : Робить запис &gt;\nClient \&quot;1\&quot; -- \&quot;0..*\&quot; Review : Залишає &gt;\nAppointment \&quot;0..*\&quot; o-- \&quot;1\&quot; Barber : Виконує &lt;\nBarber \&quot;1\&quot; *-- \&quot;1..*\&quot; Schedule : Має &gt;\nAppointment \&quot;0..*\&quot; o-- \&quot;1..*\&quot; Service : Включає &gt;\nAppointment \&quot;1\&quot; *-- \&quot;1\&quot; Invoice : Оплачується через &gt;\nInvoice \&quot;0..*\&quot; o-- \&quot;0..*\&quot; Product : Може включати товари &gt;\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="eLrlsqNE2z0tGP54ebNO-4">
